---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="关于作者与简历节选" />
	</head>
	<body>
		<Header />
		<main class="portfolio-page">
			<section class="hero">
				<div class="hero__content">
					<p class="hero__eyebrow">About</p>
					<h1>关于我</h1>
					<p class="hero__lead">
						计算机科学与技术本科在读，主攻 AIGC 内容创作与 AI 视觉实践，持续进行角色图生成、LoRA 训练、多模型工作流和镜头级内容制作。
					</p>
				</div>
			</section>

			<section class="about-grid">
				<div class="prose">
					<h2>个人简介</h2>
					<p>
						我关注 AIGC 在视觉内容生产中的实际应用，熟悉 Stable Diffusion、ComfyUI、LoRA
						训练及多模型工作流，能够围绕需求完成内容生成、效果测试、参数调整与成片优化。
					</p>
					<p>
						除 AIGC 工具外，我也具备 AI 辅助编程、PS 图像处理、剪映内容包装，以及 Java
						前后端、数据库、微信小程序等基础开发能力。
					</p>

					<h2>简历节选</h2>
					<ul>
						<li>北京伊看科技有限公司：参与 AI 漫剧项目，负责约 300 个镜头的提示词编写与模型选择。</li>
						<li>中移铁通重庆渝西分公司：参与技术支撑工作，涉及电脑装机、表格整理和企业征信信息查询。</li>
						<li>中软睿达科技有限公司：学习 Java 前后端、数据库、微信小程序及服务器部署实践。</li>
					</ul>
				</div>

				<aside class="work-sidebar">
					<section class="work-panel">
						<h2>核心技能</h2>
						<div class="chip-list">
							<span class="chip">Stable Diffusion</span>
							<span class="chip">ComfyUI</span>
							<span class="chip">LoRA</span>
							<span class="chip">SVC</span>
							<span class="chip">AI辅助编程</span>
							<span class="chip">Photoshop</span>
							<span class="chip">剪映</span>
						</div>
					</section>

					<section class="work-panel">
						<h2>证书 / 荣誉</h2>
						<ul class="about-list">
							<li>HarmonyOS 应用开发者高级认证</li>
							<li>华为人工智能初识微认证</li>
							<li>大学英语 CET-4</li>
							<li>C1 驾驶证</li>
						</ul>
					</section>

					<section class="work-panel">
						<h2>目前方向</h2>
						<p>正在持续整理作品集，优先展示 AI 角色图、风格实验、AIGC 项目案例与提示词实践。</p>
					</section>
				</aside>
			</section>
		</main>
		<Footer />
	</body>
</html>
