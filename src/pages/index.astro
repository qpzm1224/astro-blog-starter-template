---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import WorkCard from "../components/WorkCard.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { getGalleryImages } from "../utils/gallery.ts";

const images = getGalleryImages();
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="portfolio-page portfolio-page--gallery">
			<section class="hero hero--minimal">
				<div class="hero__content hero__content--minimal">
					<p class="hero__eyebrow">AIGC Visual Archive</p>
					<h1>Gallery</h1>
					<p class="hero__micro">全部作品展示</p>
				</div>
			</section>

			<section class="gallery-section gallery-section--airy">
				<div class="section-heading section-heading--compact">
					<p class="section-heading__label">All Works</p>
					<p>{images.length} 张</p>
				</div>

				<div class="work-grid work-grid--masonry">
					{images.map((image, index) => <WorkCard image={image} index={index} />)}
				</div>
			</section>
		</main>

		<dialog class="lightbox" data-lightbox-dialog>
			<button class="lightbox__close" type="button" data-close-lightbox>关闭</button>
			<img src="" alt="" data-lightbox-image width="2000" height="1500" />
		</dialog>

		<script>
			const dialog = document.querySelector("[data-lightbox-dialog]");
			const dialogImage = document.querySelector("[data-lightbox-image]");
			const closeButton = document.querySelector("[data-close-lightbox]");
			if (dialog instanceof HTMLDialogElement && dialogImage instanceof HTMLImageElement && closeButton) {
				document.querySelectorAll("[data-lightbox]").forEach((link) => {
					link.addEventListener("click", (event) => {
						event.preventDefault();
						const target = event.currentTarget;
						if (!(target instanceof HTMLAnchorElement)) return;
						dialogImage.src = target.dataset.lightboxSrc || target.href;
						dialogImage.alt = target.dataset.lightboxAlt || "";
						dialog.showModal();
					});
				});
				closeButton.addEventListener("click", () => dialog.close());
				dialog.addEventListener("click", (event) => {
					if (event.target === dialog) dialog.close();
				});
			}
		</script>
		<Footer />
	</body>
</html>
