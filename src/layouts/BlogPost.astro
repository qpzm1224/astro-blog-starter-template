---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"blog">["data"];

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	prompt,
	tools = [],
	tags = [],
	client,
} = Astro.props;

const published = pubDate
	? new Intl.DateTimeFormat("zh-CN", { year: "numeric", month: "short" }).format(pubDate)
	: null;
const updated = updatedDate
	? new Intl.DateTimeFormat("zh-CN", { year: "numeric", month: "short" }).format(updatedDate)
	: null;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main class="work-detail-page">
			<article class="work-detail">
				<div class="work-detail__hero">
					<img id="work-hero-image" src={heroImage} alt={title} width="1600" height="1200" />
					<button class="work-detail__zoom" type="button" data-open-lightbox>
						查看大图
					</button>
				</div>

				<div class="work-detail__intro">
					<div>
						<p class="section-heading__label">Project</p>
						<h1>{title}</h1>
						<p class="work-detail__description">{description}</p>
					</div>

					<div class="work-meta">
						{published && (
							<div>
								<span>时间</span>
								<strong>{published}</strong>
							</div>
						)}
						{client && (
							<div>
								<span>项目</span>
								<strong>{client}</strong>
							</div>
						)}
						{updated && (
							<div>
								<span>更新</span>
								<strong>{updated}</strong>
							</div>
						)}
					</div>
				</div>

				{tags.length > 0 && (
					<div class="chip-list">
						{tags.map((tag) => <span class="chip">{tag}</span>)}
					</div>
				)}

				<div class="work-detail__content">
					<div class="prose">
						<slot />
					</div>

					<aside class="work-sidebar">
						{tools.length > 0 && (
							<section class="work-panel">
								<h2>使用工具</h2>
								<div class="chip-list">
									{tools.map((tool) => <span class="chip chip--soft">{tool}</span>)}
								</div>
							</section>
						)}

						{prompt && (
							<section class="work-panel">
								<h2>提示词 / Prompt</h2>
								<pre><code>{prompt}</code></pre>
							</section>
						)}
					</aside>
				</div>
			</article>
		</main>

		<dialog class="lightbox" data-lightbox>
			<button class="lightbox__close" type="button" data-close-lightbox>关闭</button>
			<img src={heroImage} alt={title} width="2000" height="1500" />
		</dialog>

		<script>
			const dialog = document.querySelector("[data-lightbox]");
			const openButton = document.querySelector("[data-open-lightbox]");
			const closeButton = document.querySelector("[data-close-lightbox]");
			if (dialog instanceof HTMLDialogElement && openButton && closeButton) {
				openButton.addEventListener("click", () => dialog.showModal());
				closeButton.addEventListener("click", () => dialog.close());
				dialog.addEventListener("click", (event) => {
					const target = event.target;
					if (target === dialog) dialog.close();
				});
			}
		</script>
		<Footer />
	</body>
</html>
